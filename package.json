{
  "name": "workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "clients/*",
      "shared/*"
    ]
  },
  "scripts": {
    "dev": "yarn workspaces foreach --all -i -p run dev",
    "seed:cms": "yarn workspace client-cms seed"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.13"
  },
  "engines": {
    "node": "=22.x"
  },
  "packageManager": "yarn@4.9.2"
}
