{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Portfolio project with blocks and media"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "year": {
      "type": "string",
      "required": true
    },
    "blur_color": {
      "type": "string",
      "required": false
    },
    "badges": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::badge.badge",
      "inversedBy": "projects"
    },
    "cover_images": {
      "type": "component",
      "repeatable": false,
      "required": true,
      "component": "shared.responsive-image"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "portfolio.scope-block",
        "portfolio.quote-title-block",
        "portfolio.paragraph-block",
        "portfolio.images-block",
        "portfolio.results-block"
      ],
      "required": true
    }
  }
}
